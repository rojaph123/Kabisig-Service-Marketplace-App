rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return isSignedIn() && userDoc().data.role == role;
    }

    function userExists(userId) {
      return exists(/databases/$(database)/documents/users/$(userId));
    }

    function unchanged(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }

    function providerOwnerCanEdit() {
      return isSignedIn()
        && resource.data.userId == request.auth.uid
        && unchanged("isApproved")
        && unchanged("approvalStatus")
        && unchanged("moderation")
        && unchanged("earningsSummary")
        && unchanged("rating")
        && unchanged("documentsStatus");
    }

    function providerOwnerCanSubmitApplication() {
      return isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && resource.data.approvalStatus in ["Draft", "Revision Requested"]
        && request.resource.data.approvalStatus == "Pending Approval"
        && request.resource.data.isApproved == false
        && unchanged("earningsSummary")
        && unchanged("rating")
        && unchanged("documentsStatus");
    }

    function providerApplicationOwnerCanEdit() {
      return isSignedIn()
        && resource.data.userId == request.auth.uid
        && unchanged("status")
        && unchanged("reviewedBy")
        && unchanged("reviewedAt")
        && unchanged("reviewNotes");
    }

    function bookingParticipant(bookingId) {
      return isSignedIn()
        && (
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.customerId == request.auth.uid
          || get(/databases/$(database)/documents/bookings/$(bookingId)).data.providerId == request.auth.uid
        );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
        && request.resource.data.id == request.auth.uid
        && request.resource.data.role in ["customer", "provider"]
        && request.resource.data.authProvider in ["email", "google"];
      allow update: if hasRole("admin")
        || (
          isOwner(userId)
          && unchanged("role")
          && unchanged("authProvider")
          && unchanged("createdAt")
        );
      allow delete: if hasRole("admin") || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /customerProfiles/{userId} {
      allow read: if isOwner(userId) || hasRole("admin");
      allow create, update: if isOwner(userId) || hasRole("admin");
      allow delete: if hasRole("admin");
    }

    match /providerProfiles/{userId} {
      allow read: if isSignedIn();
      allow create: if hasRole("admin") || (isOwner(userId) && request.resource.data.userId == request.auth.uid);
      allow update: if hasRole("admin") || providerOwnerCanEdit() || providerOwnerCanSubmitApplication();
      allow delete: if hasRole("admin");
    }

    match /adminAuditLogs/{logId} {
      allow read: if hasRole("admin");
      allow create: if hasRole("admin");
      allow update, delete: if hasRole("admin");
    }

    match /analytics/{summaryId} {
      allow read: if hasRole("admin");
      allow create, update, delete: if hasRole("admin");
    }

    match /bookingConflicts/{conflictId} {
      allow read: if hasRole("admin");
      allow create: if isSignedIn();
      allow update, delete: if hasRole("admin");
    }

    match /bookingChangeRequests/{requestId} {
      allow read: if hasRole("admin")
        || (
          isSignedIn()
          && (
            resource.data.requestedBy == request.auth.uid
            || resource.data.targetUserId == request.auth.uid
            || bookingParticipant(resource.data.bookingId)
          )
        );
      allow create: if isSignedIn()
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.status == "Pending"
        && bookingParticipant(request.resource.data.bookingId);
      allow update, delete: if hasRole("admin");
    }

    match /bookingSlots/{slotId} {
      allow read: if hasRole("admin") || isSignedIn();
      allow create: if hasRole("admin") || isSignedIn();
      allow update: if hasRole("admin");
      allow delete: if hasRole("admin") || isSignedIn();
    }

    match /pushNotificationTokens/{tokenId} {
      allow read: if hasRole("admin") || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if hasRole("admin") || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /providerApplications/{applicationId} {
      allow read: if hasRole("admin") || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if hasRole("admin") || providerApplicationOwnerCanEdit();
      allow delete: if hasRole("admin");
    }

    match /serviceCategories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if hasRole("admin");
    }

    match /coverageAreas/{coverageAreaId} {
      allow read: if true;
      allow create, update, delete: if hasRole("admin");
    }

    match /bookings/{bookingId} {
      allow read: if hasRole("admin") || (isSignedIn() && (resource.data.customerId == request.auth.uid || resource.data.providerId == request.auth.uid));
      allow create: if (isSignedIn() && request.resource.data.customerId == request.auth.uid)
        || (
          isSignedIn()
          && request.resource.data.providerId == request.auth.uid
          && request.resource.data.status == "Accepted"
          && userExists(request.resource.data.customerId)
        );
      allow update: if hasRole("admin")
        || (
          isSignedIn()
          && resource.data.providerId == request.auth.uid
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "statusHistory", "updatedAt"])
          && request.resource.data.status in ["Accepted", "On the Way", "In Progress", "Completed"]
          && request.resource.data.customerId == resource.data.customerId
          && request.resource.data.providerId == resource.data.providerId
        )
        || (
          isSignedIn()
          && resource.data.customerId == request.auth.uid
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "statusHistory", "updatedAt"])
          && request.resource.data.status == "Cancelled"
          && request.resource.data.providerId == resource.data.providerId
        )
        || (
          isSignedIn()
          && resource.data.customerId == request.auth.uid
          && resource.data.status == "Accepted"
          && request.resource.data.status == resource.data.status
          && request.resource.data.customerId == resource.data.customerId
          && request.resource.data.providerId == resource.data.providerId
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["customerAcceptanceConfirmedAt", "customerAcceptanceConfirmedBy", "updatedAt"])
          && request.resource.data.customerAcceptanceConfirmedBy == request.auth.uid
        )
        || (
          isSignedIn()
          && resource.data.customerId == request.auth.uid
          && resource.data.status == "Pending"
          && request.resource.data.status == resource.data.status
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["address", "notes", "attachments", "updatedAt"])
          && request.resource.data.customerId == resource.data.customerId
          && request.resource.data.providerId == resource.data.providerId
        );
      allow delete: if hasRole("admin");
    }

    match /payments/{paymentId} {
      allow read: if hasRole("admin") || (isSignedIn() && (resource.data.customerId == request.auth.uid || resource.data.providerId == request.auth.uid));
      allow create: if hasRole("admin") || (
        isSignedIn()
        && (request.resource.data.customerId == request.auth.uid || request.resource.data.providerId == request.auth.uid)
      );
      allow update: if hasRole("admin") || (
        isSignedIn()
        && (resource.data.customerId == request.auth.uid || resource.data.providerId == request.auth.uid)
        && request.resource.data.customerId == resource.data.customerId
        && request.resource.data.providerId == resource.data.providerId
        && request.resource.data.bookingId == resource.data.bookingId
      );
      allow delete: if hasRole("admin");
    }

    match /messageThreads/{threadId} {
      allow read, update: if hasRole("admin") || (isSignedIn() && request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow delete: if hasRole("admin") || (isSignedIn() && request.auth.uid in resource.data.participants);
    }

    match /messages/{messageId} {
      allow read, update: if hasRole("admin") || (isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/messageThreads/$(resource.data.threadId)).data.participants);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      allow delete: if hasRole("admin") || (isSignedIn() && (resource.data.senderId == request.auth.uid || request.auth.uid in get(/databases/$(database)/documents/messageThreads/$(resource.data.threadId)).data.participants));
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if hasRole("admin");
    }

    match /notifications/{notificationId} {
      allow read, update: if hasRole("admin") || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if hasRole("admin") || (
        isSignedIn()
        && request.resource.data.userId != null
        && userExists(request.resource.data.userId)
      );
      allow delete: if hasRole("admin") || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /communityPosts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == "Open";
      allow update: if isSignedIn();
      allow delete: if hasRole("admin")
        || (
          isSignedIn()
          && (
            resource.data.customerId == request.auth.uid
            || resource.data.claimedProviderId == request.auth.uid
          )
        );
    }

    match /complaints/{reportId} {
      allow read: if hasRole("admin") || (isSignedIn() && (resource.data.submittedBy == request.auth.uid || resource.data.targetUserId == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.submittedBy == request.auth.uid;
      allow update, delete: if hasRole("admin");
    }
  }
}

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return isSignedIn() && userDoc().data.role == role;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validWorkerPaymentImage() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches("image/(jpeg|jpg|png|webp)");
    }

    match /providerDocuments/{userId}/{allPaths=**} {
      allow read: if hasRole("admin") || isOwner(userId);
      allow write: if hasRole("admin") || isOwner(userId);
    }

    match /providerPortfolio/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if hasRole("admin") || isOwner(userId);
    }

    match /workerPayments/settings/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if hasRole("admin") && validWorkerPaymentImage();
    }

    match /workerPayments/registration/{userId}/{allPaths=**} {
      allow read: if hasRole("admin") || isOwner(userId);
      allow write: if (hasRole("admin") || isOwner(userId)) && validWorkerPaymentImage();
    }

    match /workerPayments/commission/{userId}/{allPaths=**} {
      allow read: if hasRole("admin") || isOwner(userId);
      allow write: if (hasRole("admin") || isOwner(userId)) && validWorkerPaymentImage();
    }

    match /bookings/{bookingId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /communityPosts/{postId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /messages/{threadId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /reviews/{providerId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
